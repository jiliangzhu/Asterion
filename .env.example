# ============================================
# Agent Configuration
# ============================================
ASTERION_AGENT_PROVIDER=openai_compatible
ASTERION_OPENAI_COMPATIBLE_BASE_URL=https://llm-api.healwrap.cn/v1/chat/completions
ASTERION_OPENAI_COMPATIBLE_API_KEY=replace-with-your-openai-compatible-key
ASTERION_OPENAI_COMPATIBLE_MODEL=glm-5
ASTERION_OPENAI_COMPATIBLE_DISABLE_RESPONSE_FORMAT=1
ASTERION_OPENAI_COMPATIBLE_RETRIES=5

# ============================================
# Database Configuration
# ============================================
ASTERION_DB_PATH=data/asterion.duckdb
ASTERION_DB_ROLE=reader
ASTERION_STRICT_SINGLE_WRITER=1
ASTERION_WRITE_QUEUE=data/meta/write_queue.sqlite
ASTERION_DUCKDB_LOCK_RETRIES=10
ASTERION_DUCKDB_LOCK_SLEEP_S=0.1

# ============================================
# UI Configuration
# ============================================
ASTERION_UI_LITE_DB_PATH=data/ui/asterion_ui_lite.duckdb
ASTERION_UI_DB_REPLICA_PATH=data/ui/asterion_ui.duckdb
ASTERION_UI_REPLICA_COPY_MODE=auto
ASTERION_READINESS_P3_JSON_PATH=data/ui/asterion_readiness_p3.json

# ============================================
# RPC Configuration (Polygon)
# ============================================
# ASTERION_POLYGON_RPC_URL_1=https://polygon-rpc.com
# ASTERION_POLYGON_RPC_URL_2=https://rpc-mainnet.matic.network
# ASTERION_POLYGON_RPC_URL_3=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY

# ============================================
# Controlled Live Smoke (NEVER SET IN PRODUCTION)
# ============================================
# ASTERION_CONTROLLED_LIVE_SMOKE_PK_WALLET_WEATHER_1=0x...

# ============================================
# Optional: Writerd
# ============================================
# ASTERION_WRITERD=1
# ASTERION_WRITERD_ALLOWED_TABLES=trading.*,runtime.*,weather.*,resolution.*,agent.*,capability.*,ui.*
